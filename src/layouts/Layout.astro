---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Structurez les pratiques IA de votre organisation. Méthode S.F.O.I. — AI Practice Steward." } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon-32.png`} type="image/png" sizes="32x32" />
    <link rel="icon" href={`${base}favicon-16.png`} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="shortcut icon" href={`${base}favicon.ico`} />
    <meta name="theme-color" content="#2563EB" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · The B Context</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style is:global>
      /* ── Design tokens ── */
      :root {
        --primary-600: #2563eb;
        --primary-700: #1d4ed8;
        --primary-500: #3b82f6;
        --accent-500:  #8b5cf6;
        --accent-600:  #7c3aed;
        --slate-900:   #0f172a;
        --slate-800:   #1e293b;

        /* S.F.O.I. palette */
        --sfoi-s: #22c55e;
        --sfoi-f: #eab308;
        --sfoi-o: #3b82f6;
        --sfoi-i: #a855f7;
      }

      body { font-family: 'Inter', sans-serif; }

      .gradient-text {
        background: linear-gradient(135deg, var(--primary-600), var(--accent-500));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 4px 6px rgba(37,99,235,0.2);
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 12px rgba(37,99,235,0.3);
      }

      .btn-secondary {
        background: transparent;
        color: var(--primary-600);
        border: 2px solid var(--primary-600);
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        cursor: pointer;
      }
      .btn-secondary:hover {
        background: var(--primary-600);
        color: white;
        transform: translateY(-2px);
      }

      .card {
        background: white;
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid #f1f5f9;
      }
      .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.1);
        border-color: var(--primary-600);
      }

      .slide-player {
        background: white;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.12);
      }
      .progress-bar {
        height: 3px;
        background: linear-gradient(90deg, var(--primary-600), var(--accent-500));
        transition: width 0.4s ease;
      }
      .quiz-option {
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: 0.875rem 1.25rem;
        cursor: pointer;
        transition: all 0.2s;
        background: white;
        text-align: left;
        width: 100%;
        font-size: 0.9rem;
        color: #334155;
      }
      .quiz-option:hover  { border-color: var(--primary-600); background: #eff6ff; }
      .quiz-option.correct { border-color: #22c55e; background: #f0fdf4; color: #15803d; }
      .quiz-option.wrong   { border-color: #ef4444; background: #fef2f2; color: #dc2626; }

      /* ── Header ── */
      .site-header {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      /* ── Dropdown ── */
      .nav-dropdown { position: relative; }
      .nav-dropdown-menu {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 50%;
        transform: translateX(-50%);
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.625rem;
        box-shadow: 0 8px 24px rgba(0,0,0,0.10);
        min-width: 13rem;
        list-style: none;
        margin: 0;
        padding: 0.375rem;
        z-index: 200;
        transition: opacity 0.15s ease, visibility 0s linear 0.4s;
      }
      .nav-dropdown:hover .nav-dropdown-menu {
        visibility: visible;
        opacity: 1;
        transition: opacity 0.15s ease, visibility 0s;
      }
      .nav-dropdown-menu li a {
        display: block;
        padding: 0.5rem 0.875rem;
        color: #334155;
        font-size: 0.825rem;
        font-weight: 500;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: background 0.15s, color 0.15s;
      }
      .nav-dropdown-menu li a:hover { background: #f1f5f9; color: #0f172a; }
      .nav-dropdown-menu li + li { margin-top: 0.125rem; }
      .site-header .header-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 4rem;
      }
      .site-header .logo-link {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        text-decoration: none;
        flex-shrink: 0;
      }
      .site-header .logo-reflexe {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary-600);
        letter-spacing: -0.01em;
      }
      .site-header .logo-ia {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--accent-500);
        letter-spacing: -0.01em;
      }
      .site-header nav {
        position: static;
        background: none;
        border: none;
        backdrop-filter: none;
      }
      .site-header .nav-list {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .site-header .nav-link {
        color: #475569;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        transition: color 0.2s, background 0.2s;
      }
      .site-header .nav-link:hover { color: #0f172a; background: #f1f5f9; }
      .site-header .nav-cta {
        background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.4rem 1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
        margin-left: 0.5rem;
      }
      .site-header .nav-cta:hover { background: linear-gradient(135deg, var(--primary-700), var(--accent-600)); transform: translateY(-1px); }
      @media (max-width: 767px) {
        .site-header .nav-desktop { display: none; }
      }

      /* ── Hamburger button ── */
      .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.375rem;
        border-radius: 0.375rem;
        transition: background 0.2s;
      }
      .hamburger-btn:hover { background: #f1f5f9; }
      .hamburger-btn .hline {
        display: block;
        width: 22px;
        height: 2px;
        background: #334155;
        border-radius: 2px;
        transition: all 0.25s ease;
        transform-origin: center;
      }
      .hamburger-btn[aria-expanded="true"] .hline:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger-btn[aria-expanded="true"] .hline:nth-child(2) { opacity: 0; }
      .hamburger-btn[aria-expanded="true"] .hline:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      @media (max-width: 767px) { .hamburger-btn { display: flex; } }

      /* ── Mobile menu ── */
      .mobile-menu {
        display: none;
        position: fixed;
        top: 4rem;
        left: 0;
        right: 0;
        z-index: 99;
        background: white;
        border-bottom: 1px solid #e2e8f0;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        padding: 1rem 1.5rem 1.5rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
      }
      .mobile-menu.open { display: block; }
      @media (min-width: 768px) { .mobile-menu { display: none !important; } }
      .mobile-menu .mobile-nav-link {
        display: block;
        padding: 0.75rem 0;
        color: #334155;
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        border-bottom: 1px solid #f1f5f9;
        transition: color 0.2s;
      }
      .mobile-menu .mobile-nav-link:hover { color: var(--primary-600); }
      .mobile-menu .mobile-nav-link:last-child { border-bottom: none; }
      .mobile-menu .mobile-sub {
        padding-left: 1rem;
        margin-top: 0.25rem;
        margin-bottom: 0.25rem;
      }
      .mobile-menu .mobile-sub a {
        display: block;
        padding: 0.45rem 0;
        color: #64748b;
        font-size: 0.875rem;
        text-decoration: none;
        transition: color 0.2s;
      }
      .mobile-menu .mobile-sub a:hover { color: var(--primary-600); }
      .mobile-menu .mobile-section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        padding: 0.75rem 0 0.25rem;
      }
      .mobile-menu .mobile-cta {
        display: block;
        margin-top: 1rem;
        text-align: center;
        background: linear-gradient(135deg, var(--primary-600), var(--primary-700));
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
      }
      .mobile-menu .mobile-signout {
        display: block;
        width: 100%;
        margin-top: 0.5rem;
        padding: 0.75rem 0;
        background: none;
        border: none;
        cursor: pointer;
        color: #ef4444;
        font-size: 0.875rem;
        font-weight: 500;
        font-family: inherit;
        text-align: left;
      }

      /* ── Footer ── */
      .site-footer {
        background: #0f172a;
        color: white;
      }
      .site-footer .footer-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }
      .site-footer .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      @media (min-width: 768px) {
        .site-footer .footer-grid { grid-template-columns: 1fr 1fr 1fr; }
      }
      .site-footer .footer-logo-row {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-bottom: 1rem;
      }
      .site-footer .footer-logo-reflexe {
        font-size: 1.2rem;
        font-weight: 700;
        color: white;
      }
      .site-footer .footer-logo-ia {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--accent-500);
      }
      .site-footer .footer-desc {
        color: #94a3b8;
        font-size: 0.875rem;
        line-height: 1.6;
        margin-bottom: 1rem;
        max-width: 20rem;
      }
      .site-footer .footer-legal {
        color: #64748b;
        font-size: 0.75rem;
        line-height: 1.7;
      }
      .site-footer .footer-heading {
        font-size: 0.875rem;
        font-weight: 600;
        color: white;
        margin-bottom: 0.875rem;
      }
      .site-footer .footer-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .site-footer .footer-links a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.2s;
      }
      .site-footer .footer-links a:hover { color: #60a5fa; }
      .site-footer .footer-bottom {
        border-top: 1px solid #1e293b;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        text-align: center;
      }
      @media (min-width: 768px) {
        .site-footer .footer-bottom {
          flex-direction: row;
          justify-content: space-between;
          text-align: left;
        }
      }
      .site-footer .footer-bottom p { color: #475569; font-size: 0.8rem; margin: 0; }
      .site-footer .footer-bottom a { color: #60a5fa; text-decoration: none; font-size: 0.8rem; }
      .site-footer .footer-bottom a:hover { text-decoration: underline; }

      /* ── Animations ── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-up   { animation: fadeUp 0.6s ease both; }
      .animate-fade-up-1 { animation-delay: 0.1s; }
      .animate-fade-up-2 { animation-delay: 0.2s; }
      .animate-fade-up-3 { animation-delay: 0.3s; }
      .animate-fade-up-4 { animation-delay: 0.4s; }
    </style>
  </head>

  <body class="bg-white text-slate-900">

    <header class="site-header">
      <div class="header-inner">

        <a href={base} class="logo-link">
          <span>The </span><span style="color:var(--accent-500)">B</span><span> Context</span>
        </a>

        <nav aria-label="Navigation principale">
          <ul class="nav-list nav-desktop">
            <li><a href={`${base}formation/`} class="nav-link">Formation</a></li>
            <li><a href={`${base}interventions/`} class="nav-link">Interventions</a></li>
            <li class="nav-dropdown">
              <a href={`${base}framework/`} class="nav-link">Framework ▾</a>
              <ul class="nav-dropdown-menu">
                <li><a href={`${base}framework/manifeste/`}>Manifeste</a></li>
                <li><a href={`${base}framework/methode-sfoi/`}>Méthode S.F.O.I.</a></li>
                <li><a href={`${base}framework/imia/`}>IMIA</a></li>
                <li><a href={`${base}framework/ai-practice-steward/`}>AI Practice Steward</a></li>
              </ul>
            </li>
            <li><a href={`${base}mainteneurs/`} class="nav-link">Mainteneurs</a></li>
            <!-- Auth slot desktop — populated by client JS -->
            <li id="auth-nav-slot"></li>
            <li id="nav-cta-item"><a href={`${base}contact/`} class="nav-cta">Discuter →</a></li>
          </ul>
        </nav>

        <!-- Hamburger — mobile uniquement -->
        <button class="hamburger-btn" id="hamburger-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hline"></span>
          <span class="hline"></span>
          <span class="hline"></span>
        </button>

      </div>
    </header>

    <!-- Menu mobile -->
    <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
      <a href={`${base}formation/`} class="mobile-nav-link">Formation</a>
      <a href={`${base}interventions/`} class="mobile-nav-link">Interventions</a>
      <div class="mobile-nav-link" style="cursor:default;padding-bottom:0">Framework</div>
      <div class="mobile-sub">
        <a href={`${base}framework/manifeste/`}>Manifeste</a>
        <a href={`${base}framework/methode-sfoi/`}>Méthode S.F.O.I.</a>
        <a href={`${base}framework/imia/`}>IMIA</a>
        <a href={`${base}framework/ai-practice-steward/`}>AI Practice Steward</a>
      </div>
      <a href={`${base}mainteneurs/`} class="mobile-nav-link">Mainteneurs</a>
      <!-- Auth slot mobile — populated by client JS -->
      <div id="auth-mobile-slot"></div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">

          <div>
            <div class="footer-logo-row">
              <span>The </span><span style="color:var(--accent-500)">B</span><span> Context</span>
            </div>
            <p class="footer-desc">
              Transformer l'usage de l'IA générative en pratique d'équipe fiable, sécurisée et pilotable. Pour les PME et ETI.
            </p>
          </div>

          <div>
            <p class="footer-heading">Navigation</p>
            <ul class="footer-links">
              <li><a href={base}>Accueil</a></li>
              <li><a href={`${base}formation/`}>Formation</a></li>
              <li><a href={`${base}interventions/`}>Interventions</a></li>
              <li><a href={`${base}framework/`}>Framework</a></li>
              <li><a href={`${base}mainteneurs/`}>Mainteneurs</a></li>
            </ul>
          </div>

          <div>
            <p class="footer-heading">Suivre</p>
            <ul class="footer-links">
              <li>
                <a href="https://www.linkedin.com/company/the-b-context" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:0.5rem">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn — The B Context
                </a>
              </li>
            </ul>
            <div style="margin-top:1.5rem">
              <p class="footer-heading">Légal</p>
              <ul class="footer-links">
                <li><a href={`${base}mentions-legales/`}>Mentions légales</a></li>
                <li><a href={`${base}cgu/`}>CGU</a></li>
                <li><a href={`${base}politique-confidentialite/`}>Politique de confidentialité</a></li>
              </ul>
            </div>
          </div>

        </div>

        <div class="footer-bottom">
          <p>© {new Date().getFullYear()} The B Context. Tous droits réservés.</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  import { supabase } from '../lib/supabase';

  // ── Hamburger toggle ──
  const hamburgerBtn  = document.getElementById('hamburger-btn')!;
  const mobileMenu    = document.getElementById('mobile-menu')!;

  hamburgerBtn.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('open');
    hamburgerBtn.setAttribute('aria-expanded', String(open));
    mobileMenu.setAttribute('aria-hidden', String(!open));
  });

  // Close on any link click inside mobile menu
  mobileMenu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    })
  );

  // ── Auth state ──
  const desktopSlot = document.getElementById('auth-nav-slot')!;
  const ctaItem     = document.getElementById('nav-cta-item')!;
  const mobileSlot  = document.getElementById('auth-mobile-slot')!;

  async function signOut() {
    try { await supabase.auth.signOut({ scope: 'local' }); } catch (_) {}
    window.location.href = '/';
  }

  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) {
      // Desktop — Mon parcours + Se déconnecter
      desktopSlot.innerHTML = `<a href="/formation/" class="nav-link" style="color:var(--primary-600);font-weight:600">Mon parcours</a>`;
      ctaItem.style.display = 'none';
      const logoutLi  = document.createElement('li');
      const logoutBtn = document.createElement('button');
      logoutBtn.textContent = 'Se déconnecter';
      logoutBtn.className   = 'nav-link';
      logoutBtn.style.cssText = 'background:none;border:none;cursor:pointer;color:#ef4444;font-family:inherit';
      logoutLi.appendChild(logoutBtn);
      ctaItem.insertAdjacentElement('afterend', logoutLi);
      logoutBtn.addEventListener('click', signOut);

      // Mobile — Mon parcours + Se déconnecter
      const mobileLogoutBtn = document.createElement('button');
      mobileLogoutBtn.textContent = 'Se déconnecter';
      mobileLogoutBtn.className   = 'mobile-signout';
      mobileSlot.innerHTML = `<a href="/formation/" class="mobile-cta">Mon parcours →</a>`;
      mobileSlot.appendChild(mobileLogoutBtn);
      mobileLogoutBtn.addEventListener('click', signOut);
    } else {
      // Desktop — Se connecter
      desktopSlot.innerHTML = `<a href="/connexion/" class="nav-link">Se connecter</a>`;
      // Mobile — Se connecter + Formation →
      mobileSlot.innerHTML = `<a href="/connexion/" class="mobile-nav-link" style="color:var(--primary-600);font-weight:600">Se connecter</a><a href="/contact/" class="mobile-cta">Discuter →</a>`;
    }
  });
</script>
