---
import Layout from '../../layouts/Layout.astro';
import BlocCard from '../../components/BlocCard.astro';
import ArbreDecisionDownload from '../../components/ArbreDecisionDownload.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const blocs = await getCollection('formation');
blocs.sort((a, b) => a.data.bloc - b.data.bloc);
---
<Layout title="Formation Reflexe IA" description="5 blocs gratuits pour maîtriser la méthode S.F.O.I. et comprendre le rôle d'AI Practice Steward.">

  <!-- Section publique — toujours visible, teaser avant le mur d'inscription -->
  <section class="max-w-3xl mx-auto px-4 pt-16 pb-8">
    <div class="mb-4">
      <a href={base} class="text-sm text-slate-400 hover:text-slate-600 no-underline">← Accueil</a>
    </div>
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-wide mb-2" style="color:var(--primary-600)">Formation Reflexe IA — Parcours distanciel</p>
      <h1 class="text-3xl font-bold text-slate-900 mb-3">5 blocs · ~1h · À votre rythme</h1>
      <p class="text-slate-500 text-base max-w-2xl">
        De la compréhension à la maturité organisationnelle. Audio + visuels + quiz par bloc.
      </p>
    </div>
    <ArbreDecisionDownload />
  </section>

  <!-- Section formation — masquée, révélée si connecté -->
  <section class="max-w-3xl mx-auto px-4 pb-16" id="formation-content" style="display:none">

    <!-- Barre de progression — affichée si connecté -->
    <div id="progress-bar-section" class="mb-8 rounded-xl border border-slate-200 bg-slate-50 px-5 py-4" style="display:none">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-slate-700">Votre progression</span>
        <span id="progress-label" class="text-sm font-bold" style="color:var(--primary-600)">0 / 5</span>
      </div>
      <div class="h-2 rounded-full bg-slate-200 overflow-hidden">
        <div id="progress-fill" class="h-2 rounded-full transition-all" style="width:0%;background:linear-gradient(90deg,var(--primary-600),var(--accent-500))"></div>
      </div>
    </div>

    <div class="space-y-3">
      {blocs.map((entry) => (
        <BlocCard entry={entry} variant="parcours" />
      ))}
    </div>

  </section>

</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  (async () => {
    const { data: { session } } = await supabase.auth.getSession();

    // Anonyme : le teaser public reste visible, pas de redirection
    if (!session) return;

    // Révéler le contenu de formation si connecté
    const content = document.getElementById('formation-content');
    if (content) content.style.display = '';

    // Charger la progression — uniquement les blocs avec completed_at non nul
    const { data: progress } = await supabase
      .from('formation_progress')
      .select('bloc_id')
      .eq('user_id', session.user.id)
      .not('completed_at', 'is', null);

    const completed = new Set((progress ?? []).map((r: { bloc_id: string }) => r.bloc_id));
    const count = completed.size;

    // Afficher la barre de progression
    const section = document.getElementById('progress-bar-section')!;
    const label   = document.getElementById('progress-label')!;
    const fill    = document.getElementById('progress-fill')!;

    label.textContent = `${count} / 5`;
    fill.style.width  = `${(count / 5) * 100}%`;
    section.style.display = '';

    // Marquer les blocs complétés
    document.querySelectorAll<HTMLElement>('.bloc-link').forEach(link => {
      const blocId = link.dataset.blocId;
      if (blocId && completed.has(blocId)) {
        const badge = link.querySelector<HTMLElement>('.completed-badge');
        if (badge) badge.style.display = '';
        link.style.borderColor = '#86efac'; // green-300
      }
    });
  })();
</script>
