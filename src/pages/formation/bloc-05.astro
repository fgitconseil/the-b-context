---
import Layout from '../../layouts/Layout.astro';
import { BLOCS } from '../../lib/slideData';
const base = import.meta.env.BASE_URL;

const bloc = BLOCS.find(b => b.id === 'bloc-05')!;
// Last bloc — no next bloc

const slides = [

  // ── 1 ── Récap du chemin parcouru
  {
    kind: 'content',
    title: 'Récap du chemin parcouru',
    img: `${base}assets/images/m6/06-1-recap-chemin-parcouru.png`,
    imgAlt: "Récap — tout le chemin parcouru",
    mp3:   `${base}assets/audio/m6/06-1-recap-du-chemin-parcouru.mp3`,
    m4a:   `${base}assets/audio/m6/06-1-recap-du-chemin-parcouru.m4a`,
    script: [
      "Vous y êtes. Ce bloc est le dernier. Et il est un peu différent des autres.",
      "Jusqu'ici, chaque bloc vous a donné quelque chose à appliquer. Une méthode, un outil, une pratique. Ce bloc-ci va élargir la question.",
      "Dans l'Intro, vous avez compris comment fonctionne un LLM. Ce qu'il prédit, ce qu'il ne cherche pas, pourquoi il convainc sans avoir raison.",
      "En Partie 1, vous avez pris la main. Vous avez arrêté de subir vos prompts. Vous avez choisi leur intention, posé un contexte permanent dans vos Projets.",
      "En Partie 2, vous avez appliqué la méthode S.F.O.I. Sur des cas réels. Avec des résultats vérifiables.",
      "À ce stade, vous avez une compétence individuelle réelle. Ce n'est pas rien.",
      "Et pourtant, il y a quelque chose que cette formation ne peut pas résoudre à votre place. Vous allez rentrer dans votre organisation. Vos collègues ne partagent pas encore vos repères. Un individu bien formé dans un système qui ne l'est pas finit souvent par s'aligner sur le système, pas l'inverse.",
    ],
  },

  // ── 2 ── Ce que sont les skills
  {
    kind: 'content',
    title: 'Ce que sont les skills',
    img: `${base}assets/images/m6/06-2-ce-que-sont-les-skills.png`,
    imgAlt: "Skills — spécialisation d'un assistant",
    mp3:   `${base}assets/audio/m6/06-2-ce-que-sont-les-skills.mp3`,
    m4a:   `${base}assets/audio/m6/06-2-ce-que-sont-les-skills.m4a`,
    script: [
      "Un skill, c'est une spécialisation donnée à un assistant.",
      "C'est le fait de lui donner un domaine de compétence précis, une logique de travail, une façon de répondre adaptée à un contexte particulier.",
      "Un assistant sans skill est généraliste. Il fait beaucoup de choses, aucune vraiment à fond. Un assistant avec un skill ressemble à un collaborateur spécialisé. Il connaît les questions à poser dans un contexte précis.",
      "Un exemple concret : imaginez un assistant conçu pour assister lors d'un entretien avec un expert métier — pour extraire ce savoir tacite, non écrit, qui disparaît quand l'expert part. Avec un skill adapté, cet assistant suit la logique de l'entretien, propose des relances contextuelles, produit à la fin un transcript structuré, annoté, prêt à être exploité.",
      "Ce qui le rend utile n'est pas sa sophistication technique. C'est la clarté du rôle qu'on lui a donné. Et sa qualité est bornée par la compétence de celui qui l'utilise. Un skill n'amplifie pas une mauvaise compétence. Il amplifie une bonne.",
    ],
  },

  // ── 3 ── Quiz inter après slide 2
  {
    kind: 'quiz-static',
    label: 'Pause réflexion',
    question: "Un skill donné à un assistant, c'est avant tout...",
    opts: [
      "Un accès à des fonctionnalités avancées du modèle IA",
      "Une spécialisation : un domaine précis, une logique de travail adaptée à un contexte particulier",
      "Un raccourci pour éviter de rédiger des prompts détaillés",
      "Un plugin tiers connecté à l'assistant",
    ],
    answer: 1,
    expl: "Un skill ne rend pas l'assistant plus puissant — il lui donne un rôle précis. Sans skill, un assistant est généraliste. Avec un skill bien conçu, il ressemble à un collaborateur spécialisé.",
  },

  // ── 4 ── Les deux boucles
  {
    kind: 'content',
    title: 'Les deux boucles côté humain',
    img: `${base}assets/images/m6/06-3-les-deux-boucles.png`,
    imgAlt: "Les deux boucles — amplificatrice et reddition cognitive",
    mp3:   `${base}assets/audio/m6/06-3-les-deux-boucles-cote-humain.mp3`,
    m4a:   `${base}assets/audio/m6/06-3-les-deux-boucles-cote-humain.m4a`,
    script: [
      "Une capacité nouvelle crée une responsabilité nouvelle. Quand un assistant est augmenté, la question n'est plus seulement « est-ce que l'outil fonctionne ? ». Elle devient : qui supervise ? Qui valide ? Qui intervient si l'outil propose quelque chose d'inadapté ?",
      "La responsabilité ne disparaît pas dans la délégation. Elle se déplace vers le haut. Prenez un chirurgien qui intègre un assistant robotisé. Il n'est pas moins responsable de l'opération — il l'est davantage, parce qu'il a choisi d'intégrer cet outil.",
      "Il y a deux boucles qu'un assistant augmenté peut déclencher. La première : la boucle amplificatrice. L'usage croît. La vérification diminue, discrètement, par habitude. Et un jour, une erreur non détectée cause du tort. Cette boucle ne s'arrête pas d'elle-même.",
      "La deuxième est plus lente et plus profonde : la reddition cognitive. L'équipe délègue progressivement son raisonnement à l'outil. Et l'équipe perd, lentement, la compétence même de vérification. La question ne devient plus « est-ce que l'IA se trompe ? ». Elle devient : « sommes-nous encore capables de le détecter ? »",
      "Ces deux boucles ne sont pas hypothétiques. Elles se construisent dès aujourd'hui dans les organisations qui utilisent l'IA. Elles sont visibles, quand on sait quoi regarder. Et elles sont interruptibles, avant de devenir des problèmes structurels.",
    ],
  },

  // ── 5 ── Quiz inter après slide 4
  {
    kind: 'quiz-static',
    label: 'Pause réflexion',
    question: "Ce qui distingue fondamentalement la reddition cognitive de la boucle amplificatrice, c'est que...",
    opts: [
      "La boucle amplificatrice est plus rapide à se mettre en place",
      "La reddition cognitive est délibérée — l'équipe décide consciemment de déléguer",
      "La reddition cognitive atteint la capacité collective à détecter les erreurs, pas seulement leur fréquence",
      "La boucle amplificatrice est irréversible",
    ],
    answer: 2,
    expl: "La boucle amplificatrice produit des erreurs non vérifiées. La reddition cognitive va plus loin : l'équipe perd progressivement la compétence même de vérification. La question n'est plus « l'IA se trompe-t-elle ? » mais « sommes-nous encore capables de le détecter ? »",
  },

  // ── 6 ── Le rôle — AI Practice Steward
  {
    kind: 'content',
    title: "Le rôle qui émerge — l'AI Practice Steward",
    img: `${base}assets/images/m6/06-4-role-ai-practice-steward.png`,
    imgAlt: "L'AI Practice Steward — trois capacités distinctives",
    mp3:   `${base}assets/audio/m6/06-4-le-role-que-ca-cree-ai-practice-steward.mp3`,
    m4a:   `${base}assets/audio/m6/06-4-le-role-que-ca-cree-ai-practice-steward.m4a`,
    script: [
      "Il y a trois rôles qui circulent autour de l'IA en organisation. Souvent confondus. Pas interchangeables.",
      "Un formateur enseigne ce qui est. Il transmet une méthode, des repères, des pratiques. C'est ce que vous venez de vivre. Un consultant prescrit une solution. Il arrive avec une analyse, repart avec un livrable.",
      "Un AI Practice Steward travaille sur ce qui ne se voit pas encore. Les pratiques qui dérivent. Les normes qui manquent. Les boucles qui s'installent. La différence n'est pas de degré. Elle est de nature.",
      "Trois capacités distinguent l'AI Practice Steward. Voir les boucles en temps réel — pas les identifier après coup, les reconnaître pendant qu'elles se construisent. Travailler à plusieurs niveaux simultanément — de la méthode personnelle S.F.O.I. à la maturité organisationnelle mesurée par l'IMIA. L'AI Practice Steward travaille aux deux échelles en même temps. Tenir la résistance — les organisations résistent au changement, même quand elles le demandent. L'AI Practice Steward travaille avec la résistance, pas contre elle.",
      "C'est ce qui distingue le stewardship des pratiques IA du consulting IA : le consultant prescrit une solution. L'AI Practice Steward travaille sur le système qui produit le problème.",
    ],
  },

  // ── 7 ── Quiz inter après slide 6
  {
    kind: 'quiz-static',
    label: 'Pause réflexion',
    question: "Cette formation vous a donné une méthode individuelle solide. Qu'est-ce qu'elle ne peut pas résoudre à votre place ?",
    opts: [
      "La technique — vous aurez besoin d'un consultant pour configurer les outils",
      "Le fait que vos collègues n'ont pas les mêmes repères, et que la compétence individuelle ne change pas le système",
      "La motivation — sans accompagnement, il est difficile de maintenir les nouvelles pratiques",
      "L'autorisation — votre organisation devra valider formellement chaque usage IA",
    ],
    answer: 1,
    expl: "Un individu bien formé dans un système qui ne l'est pas finit souvent par s'aligner sur le système. La formation donne la méthode individuelle. Ce qui manque, c'est un travail sur le système lui-même — les boucles, les niveaux S.F.O.I. collectifs, la résistance organisationnelle.",
  },

  // ── 8 ── Clôture
  {
    kind: 'content',
    title: 'Clôture',
    img: `${base}assets/images/m6/06-5-cloture.png`,
    imgAlt: "Clôture — fin de la formation",
    mp3:   `${base}assets/audio/m6/06-5-cloture.mp3`,
    m4a:   `${base}assets/audio/m6/06-5-cloture.m4a`,
    script: [
      "Cette formation vous a donné la méthode individuelle.",
      "Comment fonctionne l'IA, comment la piloter, comment en faire un outil de votre compétence plutôt qu'une dépendance.",
      "Ce que vous faites maintenant avec ces outils dans votre organisation, c'est là que ça devient intéressant.",
      "Quand votre organisation se posera la question — pas « comment utiliser l'IA », mais « comment faire en sorte que les pratiques changent vraiment, que les boucles ne s'emballent pas, que la compétence collective se construise » — c'est exactement ce qu'on adresse en accompagnement.",
      "Pas une formation de plus. Un travail sur le système.",
      "Si cette question vous parle, la porte est ouverte.",
    ],
  },

  // ── 9 ── Écran de fin (END SCREEN)
  { kind: 'endscreen' },
];

const TOTAL = slides.length; // 9
---

<Layout title={bloc.titre}>
  <section class="max-w-2xl mx-auto px-4 py-8" id="slides-root">

    <!-- Breadcrumb -->
    <nav class="mb-5 text-sm text-slate-400">
      <a href={`${base}formation/`} class="hover:text-slate-700 no-underline transition-colors">← Parcours</a>
      <span class="mx-2">·</span>
      <span>{bloc.phase}</span>
    </nav>

    <h1 class="text-xl font-bold text-slate-900 mb-5">{bloc.titre}</h1>

    <!-- Barre de progression -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span id="slide-counter" class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Slide 1 / {TOTAL}</span>
        <span id="slide-title-badge" class="text-xs text-slate-400"></span>
      </div>
      <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
        <div id="progress-fill" class="h-full bg-purple-600 rounded-full transition-all duration-300" style={`width: ${(1 / TOTAL * 100).toFixed(2)}%`}></div>
      </div>
    </div>

    <!-- Container des slides -->
    <div id="slides-container">
      {slides.map((slide: any, i: number) => (
        <div class="slide-panel" id={`panel-${i}`} style={i > 0 ? 'display:none' : ''}>

          {/* ── CONTENU ── */}
          {slide.kind === 'content' && (
            <div>
              <h2 class="text-base font-semibold text-purple-700 mb-4">{slide.title}</h2>

              {/* Image avec overlay play */}
              <div class="img-player-wrap mb-4 rounded-xl overflow-hidden border border-slate-100 bg-slate-50"
                   onclick="imgPlayToggle(this)"
                   role="button" tabindex="0"
                   onkeydown="if(event.key==='Enter'||event.key===' ')imgPlayToggle(this)"
                   style="position:relative; cursor:pointer;">
                <img
                  src={slide.img}
                  alt={slide.imgAlt}
                  style="width:100%; max-height:480px; object-fit:contain; display:block;"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
                <div class="play-overlay" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;">
                  <div class="play-circle">
                    <svg class="play-icon" width="30" height="30" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                      <polygon points="7,3 21,12 7,21"/>
                    </svg>
                    <svg class="pause-icon" width="30" height="30" viewBox="0 0 24 24" fill="white" aria-hidden="true" style="display:none">
                      <rect x="4"  y="3" width="5" height="18" rx="1"/>
                      <rect x="15" y="3" width="5" height="18" rx="1"/>
                    </svg>
                  </div>
                </div>
                <button class="zoom-btn" onclick="event.stopPropagation();openLightbox(this.parentElement.querySelector('img'))" aria-label="Agrandir l'image">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="15,3 21,3 21,9"/><polyline points="9,21 3,21 3,15"/>
                    <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
                  </svg>
                </button>
              </div>

              {/* Audio */}
              <div class="mb-4">
                <audio controls preload="metadata" style="width:100%">
                  <source src={slide.mp3} type="audio/mpeg" />
                  <source src={slide.m4a} type="audio/mp4" />
                  Votre navigateur ne supporte pas la lecture audio.
                </audio>
              </div>

              <details class="border border-slate-200 rounded-xl overflow-hidden">
                <summary class="s-summary px-4 py-3 text-sm font-medium text-slate-600 hover:bg-slate-50 cursor-pointer transition-colors">
                  Voir le script complet ▾
                </summary>
                <div class="px-4 py-4 border-t border-slate-100 bg-slate-50/60 space-y-3">
                  {slide.script.map((para: string) => (
                    <p class="text-sm text-slate-600 leading-relaxed">{para}</p>
                  ))}
                </div>
              </details>
            </div>
          )}

          {/* ── QUIZ STATIQUE (non-bloquant) ── */}
          {slide.kind === 'quiz-static' && (
            <div>
              <div class="flex items-center gap-2 mb-5">
                <span class="text-xs font-semibold bg-amber-100 text-amber-700 px-2.5 py-1 rounded-full uppercase tracking-wide">Pause réflexion</span>
              </div>
              <p class="text-base font-semibold text-slate-900 mb-5 leading-snug">{slide.question}</p>
              <div class="quiz-block space-y-2" data-answer={slide.answer}>
                {slide.opts.map((opt: string, j: number) => (
                  <button
                    type="button"
                    class="quiz-opt w-full text-left px-4 py-3 rounded-lg border border-slate-200 bg-white text-sm text-slate-700 hover:border-amber-400 hover:bg-amber-50 transition-all"
                    data-index={String(j)}
                    onclick="handleQuizAnswer(this)"
                  >
                    <span class="font-semibold text-amber-600 mr-2">{String.fromCharCode(65 + j)})</span>{opt}
                  </button>
                ))}
                <div class="quiz-expl px-4 py-4 rounded-xl bg-slate-50 border border-slate-200 text-sm text-slate-600 leading-relaxed mt-3" style="display:none">
                  {slide.expl}
                </div>
              </div>
            </div>
          )}

          {/* ── END SCREEN ── */}
          {slide.kind === 'endscreen' && (
            <div class="py-8">
              <div id="end-bloc-05" style="display:none"></div>

              <!-- Titre -->
              <div class="text-center mb-8">
                <div class="w-16 h-16 rounded-full bg-purple-600 flex items-center justify-center mx-auto mb-4">
                  <span class="text-white text-2xl">★</span>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 mb-2">Vous avez terminé la formation Reflexe IA.</h2>
                <p class="text-slate-500 max-w-md mx-auto">Vous disposez d'une méthode personnelle — S.F.O.I. — et d'une grille de lecture pour ce qui dépasse l'individu : l'IMIA et le rôle d'AI Practice Steward.</p>
              </div>

              <!-- Badge LinkedIn -->
              <div class="mb-6 p-5 rounded-xl bg-slate-50 border border-slate-200">
                <p class="text-sm font-semibold text-slate-700 mb-3">Partagez votre progression</p>
                <p class="text-sm text-slate-500 mb-4">Vous avez acquis une méthode concrète pour utiliser l'IA de façon rigoureuse et responsable. Si ce parcours vous a été utile, vous pouvez le signaler sur votre profil LinkedIn.</p>
                <a
                  href="https://www.linkedin.com/profile/add?startTask=FORMATION-REFLEXE-IA&name=Formation%20Reflexe%20IA%20%E2%80%94%20M%C3%A9thode%20S.F.O.I.&organizationId=112952006&issueYear=2026&issueMonth=4&certUrl=https%3A%2F%2Freflexe-ia.org%2Fformation%2F"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#0A66C2] text-white text-sm font-semibold hover:bg-[#004182] transition-colors"
                >
                  Partager sur LinkedIn
                </a>
              </div>

              <!-- CTA Accompagnement -->
              <div class="p-6 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-800 text-white">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2">Aller plus loin</p>
                <h3 class="text-lg font-bold mb-2">Vos collaborateurs ont suivi la formation — mais les pratiques ne changent pas dans l'organisation ?</h3>
                <p class="text-slate-300 text-sm mb-4 leading-relaxed">Ce n'est pas un problème de compétence. C'est un problème de système.<br />C'est exactement ce qu'adresse un accompagnement par un AI Practice Steward.</p>
                <div class="flex flex-col sm:flex-row gap-3">
                  <a href="/framework/ai-practice-steward/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white text-slate-900 text-sm font-semibold hover:bg-slate-100 transition-colors">Découvrir le rôle →</a>
                </div>
              </div>
            </div>
          )}

        </div>
      ))}
    </div>

    <!-- Navigation -->
    <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
      <button id="prev-btn" onclick="slidePrev()" disabled
        class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:border-slate-300 disabled:opacity-30 disabled:cursor-not-allowed transition-all">
        ← Précédent
      </button>
      <button id="next-btn" onclick="slideNext()"
        class="px-5 py-2.5 rounded-lg bg-purple-600 text-white text-sm font-medium hover:bg-purple-700 transition-all">
        Suivant →
      </button>
    </div>

  </section>

  <div id="lightbox" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.88); align-items:center; justify-content:center;" onclick="closeLightbox()" role="dialog" aria-modal="true">
    <img id="lightbox-img" src="" alt="" style="max-width:92vw; max-height:90vh; object-fit:contain; border-radius:8px; box-shadow:0 8px 40px rgba(0,0,0,0.5);" />
    <button onclick="event.stopPropagation();closeLightbox()" style="position:absolute;top:16px;right:20px;background:rgba(255,255,255,0.15);border:1.5px solid rgba(255,255,255,0.3);border-radius:50%;width:40px;height:40px;cursor:pointer;color:white;font-size:20px;display:flex;align-items:center;justify-content:center;" aria-label="Fermer l'image agrandie">✕</button>
  </div>

</Layout>

<style>
  details summary.s-summary { list-style: none; }
  details summary.s-summary::-webkit-details-marker { display: none; }
  .quiz-opt.q-correct { border-color: #22c55e !important; background-color: #f0fdf4 !important; color: #15803d !important; }
  .quiz-opt.q-wrong { border-color: #f87171 !important; background-color: #fef2f2 !important; color: #dc2626 !important; }
  .quiz-opt.q-inactive { opacity: 0.4; cursor: default; }
  .play-circle {
    width: 68px; height: 68px;
    border-radius: 50%;
    background: rgba(0,0,0,0.52);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, transform 0.15s;
  }
  .img-player-wrap:hover .play-circle {
    background: rgba(0,0,0,0.72);
    transform: scale(1.07);
  }
  .zoom-btn {
    position: absolute;
    bottom: 8px; right: 8px;
    width: 32px; height: 32px;
    border-radius: 6px;
    background: rgba(0,0,0,0.5);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    opacity: 0.8;
    transition: opacity 0.15s, transform 0.15s;
    z-index: 2;
  }
  .zoom-btn:hover { opacity: 1; transform: scale(1.1); }
</style>

<script is:inline>
  var current = 0;
  var TOTAL = 9;

  function showSlide(n) {
    // Pause audio of current slide
    var curPanel = document.getElementById('panel-' + current);
    if (curPanel) {
      var curAudio = curPanel.querySelector('audio');
      if (curAudio) { curAudio.pause(); curAudio.currentTime = 0; }
    }

    document.querySelectorAll('.slide-panel').forEach(function(p, i) {
      p.style.display = i === n ? 'block' : 'none';
    });
    current = n;

    // Autoplay audio on content slides
    var newPanel = document.getElementById('panel-' + n);
    if (newPanel) {
      var newAudio = newPanel.querySelector('audio');
      if (newAudio) newAudio.play().catch(function() {});
    }
    setPlayOverlay(current);

    // Trigger completion on end screen (last slide)
    if (n === TOTAL - 1) {
      var endEl = document.getElementById('end-bloc-05');
      if (endEl) endEl.style.display = 'block';
    }

    var pct = ((n + 1) / TOTAL * 100).toFixed(2) + '%';
    document.getElementById('progress-fill').style.width = pct;
    document.getElementById('slide-counter').textContent = 'Slide ' + (n + 1) + ' / ' + TOTAL;
    document.getElementById('prev-btn').disabled = n === 0;

    // Hide nav buttons on end screen
    var prevBtn = document.getElementById('prev-btn');
    var nextBtn = document.getElementById('next-btn');
    prevBtn.style.display = n === TOTAL - 1 ? 'none' : '';
    nextBtn.style.display = n === TOTAL - 1 ? 'none' : '';
  }

  function slidePrev() {
    if (current > 0) showSlide(current - 1);
  }

  function slideNext() {
    if (current < TOTAL - 1) showSlide(current + 1);
  }

  function setPlayOverlay(n) {
    var panel = document.getElementById('panel-' + n);
    if (!panel) return;
    var audio = panel.querySelector('audio');
    var playing = audio && !audio.paused;
    var playIco  = panel.querySelector('.play-icon');
    var pauseIco = panel.querySelector('.pause-icon');
    if (playIco)  playIco.style.display  = playing ? 'none'  : 'block';
    if (pauseIco) pauseIco.style.display = playing ? 'block' : 'none';
  }

  function imgPlayToggle(wrapper) {
    var panel = wrapper.closest('.slide-panel');
    var audio = panel.querySelector('audio');
    if (!audio) return;
    if (audio.paused) {
      audio.play().catch(function() {});
    } else {
      audio.pause();
    }
  }

  // Sync overlay icon with native player events
  document.querySelectorAll('.slide-panel audio').forEach(function(audio) {
    var idx = parseInt(audio.closest('.slide-panel').id.replace('panel-', ''), 10);
    audio.addEventListener('play',  function() { setPlayOverlay(idx); });
    audio.addEventListener('pause', function() { setPlayOverlay(idx); });
    audio.addEventListener('ended', function() { setPlayOverlay(idx); });
  });

  function handleQuizAnswer(btn) {
    var block = btn.closest('.quiz-block');
    if (block.dataset.answered) return;
    block.dataset.answered = '1';
    var correct = parseInt(block.dataset.answer, 10);
    var chosen = parseInt(btn.dataset.index, 10);
    block.querySelectorAll('.quiz-opt').forEach(function(opt, i) {
      opt.disabled = true;
      if (i === correct) opt.classList.add('q-correct');
      else if (i === chosen && chosen !== correct) opt.classList.add('q-wrong');
      else opt.classList.add('q-inactive');
    });
    var expl = block.querySelector('.quiz-expl');
    if (expl) expl.style.display = 'block';
  }

  function openLightbox(imgEl) {
    var lb = document.getElementById('lightbox');
    document.getElementById('lightbox-img').src = imgEl.src;
    document.getElementById('lightbox-img').alt = imgEl.alt || '';
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
  });

  showSlide(0);
</script>

<script>
  import { trackBlocCompletion, observeEndScreen, saveSlideProgress, loadSlideProgress } from '../../lib/trackCompletion';

  const BLOC_ID = 'bloc-05';
  observeEndScreen(BLOC_ID, () => trackBlocCompletion(BLOC_ID));

  loadSlideProgress(BLOC_ID).then((idx) => {
    function setup() {
      if (typeof (window as any).showSlide !== 'function') { setTimeout(setup, 50); return; }
      const orig = (window as any).showSlide as (n: number) => void;
      (window as any).showSlide = (n: number) => { orig(n); saveSlideProgress(BLOC_ID, n); };
      if (idx > 0) (window as any).showSlide(idx);
    }
    setup();
  });
</script>
