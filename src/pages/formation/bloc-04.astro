---
import Layout from '../../layouts/Layout.astro';
import SlidePlayer from '../../components/SlidePlayer.astro';
import { getEntry } from 'astro:content';
const base = import.meta.env.BASE_URL;

const entry = await getEntry('formation', 'bloc-04');
if (!entry) return Astro.redirect(`${base}formation/`);

const nextBlocUrl = `${base}formation/bloc-05/`;
---
<Layout title={entry.data.titre}>
  <SlidePlayer {entry} blocId="bloc-04" {nextBlocUrl} phaseLabel="Méthode" />
</Layout>
