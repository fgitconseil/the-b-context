---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const mainteneurs = [
  {
    slug: 'fayaz-goulam',
    nom: 'Fayaz Goulam',
    role: 'Fondateur de Reflexe IA — AI Practice Steward',
    photo: '/images/mainteneurs/fayaz-goulam.jpg',
    presentation: [
      "Fayaz Goulam est le fondateur de Reflexe IA et le premier praticien du rôle d'AI Practice Steward. Son parcours couvre deux décennies à la croisée de la gestion de la connaissance, des technologies sémantiques, du pilotage de programmes de transformation et de la direction de fonctions Data & IA — chez France Télévisions, Kering, Bpifrance et actuellement ARiSTiD, où il occupe le poste de Head of Data & AI.",
      "Cette trajectoire a nourri la conviction qui anime Reflexe IA : les pratiques IA en organisation ne sont pas un problème d'outils ni de formations isolées. Elles sont un problème de gouvernance distribuée, de savoirs à capitaliser et de boucles systémiques à interrompre — ce qu'aucun dispositif traditionnel ne traite de front.",
      "Fayaz conduit aujourd'hui la construction du framework Reflexe IA et l'animation du collectif des Mainteneurs. Il intervient en mission d'AI Practice Steward auprès d'organisations qui veulent installer des pratiques IA fiables et durables.",
    ],
    linkedin: 'https://www.linkedin.com/in/fayazgoulam/',
  },
];
---
<Layout title="Les Mainteneurs" description="Les créateurs et premiers praticiens du framework Reflexe IA — Mainteneurs · Reflexe IA">

  <section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white py-20">
    <div class="max-w-3xl mx-auto px-6">
      <div class="mb-4">
        <a href={base} class="text-slate-400 text-sm hover:text-slate-200 no-underline">← Accueil</a>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Les Mainteneurs</h1>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-6 py-16 space-y-12">

    <section class="space-y-4 text-slate-700 text-base leading-relaxed">
      <p>
        Reflexe IA est aujourd'hui porté par <strong>Fayaz Goulam</strong> (FGIT Conseil).
      </p>
      <p>
        Les Mainteneurs sont les créateurs du framework et ses premiers praticiens — ceux qui réalisent les premières missions d'AI Practice Steward, font vivre la méthode par leur pratique terrain, et la font évoluer par retour d'expérience.
      </p>
      <p>Ce ne sont pas des théoriciens du rôle. Ce sont ceux qui le font exister.</p>
    </section>

    <!-- Distinction -->
    <section class="rounded-xl border border-slate-200 bg-slate-50 p-6">
      <p class="text-xs font-bold uppercase tracking-wide text-slate-400 mb-4">À ne pas confondre</p>
      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <p class="font-semibold text-slate-900 text-sm mb-1">AI Practice Steward</p>
          <p class="text-slate-500 text-sm">Rôle de marché que les organisations vont chercher à développer en interne ou à recruter.</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900 text-sm mb-1">Mainteneurs</p>
          <p class="text-slate-500 text-sm">Collectif qui construit et fait évoluer le framework — méthode S.F.O.I., définition du rôle, ressources ouvertes.</p>
        </div>
      </div>
    </section>

    <!-- Profils Mainteneurs -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-8">Mainteneurs</h2>
      <div class="space-y-10">
        {mainteneurs.map(m => (
          <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="grid md:grid-cols-[280px_1fr] gap-0">

              <!-- Photo -->
              <div class="flex items-start justify-center md:justify-start p-8 md:p-0">
                <img
                  src={m.photo}
                  alt={`Photo de ${m.nom}`}
                  width="280"
                  height="420"
                  loading="lazy"
                  decoding="async"
                  class="w-40 md:w-full h-auto md:h-full object-cover object-top rounded-2xl md:rounded-none md:rounded-l-2xl"
                />
              </div>

              <!-- Infos -->
              <div class="px-8 py-8 flex flex-col justify-center space-y-5">
                <div>
                  <h3 class="text-2xl font-bold text-slate-900">{m.nom}</h3>
                  <p class="text-sm font-medium mt-1" style="color:var(--primary-600)">{m.role}</p>
                </div>

                <div class="space-y-3 text-slate-600 text-sm leading-relaxed">
                  {m.presentation.map(p => (
                    <p>{p}</p>
                  ))}
                </div>

                <a
                  href={m.linkedin}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 text-sm font-medium no-underline transition-colors"
                  style="color:var(--primary-600)"
                  onmouseover="this.style.color='var(--primary-700)'"
                  onmouseout="this.style.color='var(--primary-600)'"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn →
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Rejoindre -->
    <section class="rounded-2xl bg-slate-50 border border-slate-200 p-8">
      <h2 class="text-xl font-bold text-slate-900 mb-3">Rejoindre les Mainteneurs</h2>
      <p class="text-slate-600 text-base leading-relaxed mb-4">
        La communauté des Mainteneurs est en construction. Les premiers praticiens seront invités à rejoindre à l'automne 2026, sur la base de leur pratique documentée — pas d'un examen.
      </p>
      <blockquote class="border-l-4 border-slate-300 pl-4 my-4 text-slate-600 text-sm leading-relaxed italic">
        Le modèle : Linux / Red Hat plutôt que SAFe. La méthode est ouverte. L'expertise s'atteste par la pratique.
      </blockquote>
      <p class="text-slate-600 text-base leading-relaxed mb-6">
        Pour exprimer votre intérêt :
      </p>
      <a
        href="https://calendly.com/conversation-reflexe-ia/30min"
        target="_blank"
        rel="noopener"
        class="btn-primary"
      >Prendre 30 minutes →</a>
    </section>

  </div>

</Layout>
