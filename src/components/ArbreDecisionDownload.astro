---
interface Props {
  lead?: string;
}
const { lead = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!-- Arbre de décision — deux états gérés côté client selon la session -->
<div class="arbre-decision-download rounded-xl border border-slate-200 bg-slate-50 p-5 flex flex-col sm:flex-row sm:items-center gap-4">
  <div class="flex-1 min-w-0">
    {lead && <p class="text-xs font-bold uppercase tracking-wide text-slate-400 mb-2">{lead}</p>}
    <p class="font-bold text-slate-900 mb-1">L'arbre de décision Reflexe IA</p>
    <p class="text-slate-500 text-sm leading-relaxed">3 questions pour situer un usage d'IA générative et choisir jusqu'où aller.</p>
    <p data-arbre="mention" class="text-xs text-slate-400 mt-2">Inclus avec la formation gratuite</p>
  </div>
  <div class="flex-shrink-0 flex flex-col items-start sm:items-end gap-2">
    <!-- Anonyme : CTA inscription -->
    <a
      data-arbre="anon"
      href={`${base}inscription/`}
      class="btn-primary text-sm inline-block whitespace-nowrap"
    >
      S'inscrire pour y accéder
    </a>
    <!-- Connecté : téléchargement PDF (filename explicite pour forcer le download) -->
    <a
      data-arbre="auth"
      href={`${base}assets/arbre-decision-reflexe-ia.pdf`}
      download="arbre-decision-reflexe-ia.pdf"
      class="btn-primary text-sm inline-block whitespace-nowrap"
      style="display:none"
    >
      Télécharger le PDF
    </a>
    <!-- Lien secondaire — visible uniquement si connecté (fichier .htm à déposer dans public/assets/) -->
    <a
      data-arbre="consulter"
      href={`${base}assets/arbre-decision-reflexe-ia.htm`}
      target="_blank"
      rel="noopener"
      class="text-xs text-slate-400 hover:text-slate-600 underline"
      style="display:none"
    >
      Consulter en ligne
    </a>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  (async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) return;

    // Bascule vers l'état connecté sur toutes les instances présentes
    document.querySelectorAll('.arbre-decision-download').forEach(el => {
      el.querySelector<HTMLElement>('[data-arbre="anon"]')?.style.setProperty('display', 'none');
      el.querySelector<HTMLElement>('[data-arbre="mention"]')?.style.setProperty('display', 'none');
      el.querySelector<HTMLElement>('[data-arbre="auth"]')?.style.removeProperty('display');
      el.querySelector<HTMLElement>('[data-arbre="consulter"]')?.style.removeProperty('display');
    });
  })();
</script>
