---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'formation'>;
  variant: 'parcours' | 'syllabus';
}

const { entry, variant } = Astro.props;
const base = import.meta.env.BASE_URL;
const { bloc, titre, duree_estimee, categorie, accroche, takeaway } = entry.data;

const blocId = `bloc-0${bloc}`;
const href = `${base}formation/${blocId}/`;

const colorMap: Record<string, { circle: string; tag: string }> = {
  'Comprendre': { circle: 'bg-blue-600',   tag: 'bg-blue-50 text-blue-700' },
  'Choisir':    { circle: 'bg-green-600',  tag: 'bg-green-50 text-green-700' },
  'Méthode':    { circle: 'bg-amber-500',  tag: 'bg-amber-50 text-amber-700' },
  'Ouverture':  { circle: 'bg-purple-600', tag: 'bg-purple-50 text-purple-700' },
};

const colors = colorMap[categorie ?? ''] ?? { circle: 'bg-slate-600', tag: 'bg-slate-50 text-slate-700' };
const hasTakeaway = !!takeaway;
---

{variant === 'parcours' ? (
  <a
    href={href}
    data-bloc-id={blocId}
    class="bloc-link flex items-start gap-4 p-5 rounded-xl border border-slate-100 hover:border-blue-300 hover:shadow-md transition-all bg-white group no-underline"
  >
    <div class:list={['w-9 h-9 rounded-full text-white flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5', colors.circle]}>
      {bloc}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap mb-1">
        <span class="font-semibold text-slate-900 text-sm group-hover:text-blue-700 transition-colors">{titre}</span>
        <span class="text-xs text-slate-400">{duree_estimee}</span>
        {hasTakeaway && (
          <span class="text-xs bg-blue-50 text-blue-600 border border-blue-100 px-2 py-0.5 rounded-full font-medium">Fiche mémo</span>
        )}
        <span class="completed-badge text-xs bg-green-50 text-green-700 border border-green-200 px-2 py-0.5 rounded-full font-medium" style="display:none">✓ Complété</span>
      </div>
      <div class="mb-1">
        <span class:list={['inline-block px-2 py-0.5 rounded-full text-xs font-semibold', colors.tag]}>{categorie}</span>
      </div>
      <p class="text-slate-500 text-sm leading-relaxed">{accroche}</p>
    </div>
    <span class="text-slate-300 group-hover:text-blue-500 transition-colors self-center flex-shrink-0 text-lg">→</span>
  </a>
) : (
  <div class="flex items-start gap-4 p-4 rounded-xl bg-white border border-slate-100">
    <div class:list={['w-8 h-8 rounded-full text-white flex items-center justify-center font-bold text-xs flex-shrink-0 mt-0.5', colors.circle]}>
      {bloc}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap mb-0.5">
        <span class="font-semibold text-slate-900 text-sm">{titre}</span>
        <span class="text-xs text-slate-400">{duree_estimee}</span>
        {hasTakeaway && (
          <span class="text-xs bg-blue-50 text-blue-600 border border-blue-100 px-2 py-0.5 rounded-full font-medium">Fiche mémo</span>
        )}
        <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-full', colors.tag]}>{categorie}</span>
      </div>
      <p class="text-slate-500 text-sm leading-relaxed">{accroche}</p>
    </div>
    <span class="text-slate-300 self-center flex-shrink-0">→</span>
  </div>
)}
